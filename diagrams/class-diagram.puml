@startuml Class Diagram - Face Recognition Skincare App

title Class Diagram - Face Recognition Based Skincare Recommendation System

package "Frontend Components" {
  
  class CameraPanel {
    - videoRef: RefObject<HTMLVideoElement>
    - canvasRef: RefObject<HTMLCanvasElement>
    - mode: 'camera' | 'upload'
    - cameraReady: boolean
    - uploadedImage: string | null
    - faceBox: BoundingBox | null
    - guidanceStatus: GuidanceStatus
    + handleCapture(): void
    + handleFileChange(): void
    - analyzeFromCanvas(): AnalysisResult
    - saveToDataset(): void
  }
  
  class ResultPanel {
    - skinType: string | null
    - scores: SkinScores | null
    - isAnalyzing: boolean
    - faceDetected: boolean
    + render(): JSX.Element
  }
  
  class RecommendationCard {
    - skinType: string
    - items: Product[]
    - loading: boolean
    + useEffect(): void
    + render(): JSX.Element
  }
  
  class ModelLoader {
    - modelLoaded: boolean
    + loadModels(): Promise<void>
  }
}

package "Core Services" {
  
  class SkinAnalyzer {
    + analyzeSkin(video: HTMLVideoElement): Promise<AnalysisResult>
    + initSkinClassifier(): Promise<void>
    + initFaceDetection(): Promise<void>
    - captureFrame(): ImageData
    - detectFacePresenceWithCNN(): Promise<FaceResult>
  }
  
  class FaceDetection {
    - faceDetectionModel: Detector | null
    - isModelLoaded: boolean
    + initializeFaceDetection(): Promise<boolean>
    + detectFaces(image: HTMLElement): Promise<FaceDetectionResult>
    + detectFacesFromImageData(): Promise<FaceDetectionResult>
    + getFaceDetectionStatus(): Status
    + cleanupFaceDetection(): void
  }
  
  class CNNSkinClassifier {
    - model: LayersModel | null
    - modelLoadingPromise: Promise<void> | null
    + loadSkinModel(): Promise<void>
    + classifySkin(imageData: ImageData): Promise<CNNPrediction>
    + probabilitiesToScores(): SkinScores
    + formatLabel(): string
    + isModelLoaded(): boolean
    + disposeModel(): void
  }
}

package "Data Models" {
  
  class AnalysisResult {
    + skinType: string
    + scores: SkinScores
    + faceDetected: boolean
    + imageData?: string
    + confidence?: number
  }
  
  class FaceDetectionResult {
    + boundingBox: FaceBoundingBox | null
    + confidence: number
    + faceDetected: boolean
    + rawDetection?: unknown
  }
  
  class FaceBoundingBox {
    + x: number
    + y: number
    + width: number
    + height: number
  }
  
  class CNNPrediction {
    + label: SkinLabel
    + probabilities: Record<SkinLabel, number>
    + confidence: number
  }
  
  class SkinScores {
    + acne: number
    + blackheads: number
    + clear_skin: number
    + dark_spots: number
    + puffy_eyes: number
    + wrinkles: number
  }
  
  class Product {
    + id: number
    + name: string
    + brand_id: number | null
    + category_id: number | null
    + description: string | null
    + image_url: string | null
    + w_oily: number
    + w_dry: number
    + w_normal: number
    + w_acne: number
    + created_at: string
    + brand_name?: string
    + category_name?: string
  }
  
  class Ingredient {
    + id: number
    + name: string
    + effect: string | null
    + w_oily: number
    + w_dry: number
    + w_normal: number
    + w_acne: number
    + created_at: string
  }
  
  class AnalysisLog {
    + id: number
    + user_name: string
    + user_email: string | null
    + user_phone: string | null
    + user_age: number
    + oily_score: number
    + dry_score: number
    + normal_score: number
    + acne_score: number
    + dominant_condition: string
    + recommended_product_ids: string
    + created_at: string
  }
  
  class Brand {
    + id: number
    + name: string
    + logo_url: string | null
    + created_at: string
  }
  
  class ProductCategory {
    + id: number
    + name: string
    + description: string | null
    + created_at: string
  }
  
  class Recommendation {
    + id: number
    + condition: string
    + title: string
    + description: string | null
    + tips: string | null
    + created_at: string
  }
}

package "API Routes" {
  
  class AnalysisAPI {
    + POST(request: NextRequest): Promise<NextResponse>
    - calculateScore(): number
    - getRecommendations(): Product[]
    - getDominantCondition(): string
  }
  
  class ProductsAPI {
    + GET(): Promise<NextResponse>
    + POST(request: NextRequest): Promise<NextResponse>
  }
  
  class AnalysisLogsAPI {
    + GET(request: NextRequest): Promise<NextResponse>
  }
  
  class ReportsAPI {
    + GET /summary(): Promise<NextResponse>
    + GET /export-xlsx(): Promise<NextResponse>
    + GET /export-pdf(): Promise<NextResponse>
  }
}

package "Data Access Layer" {
  
  class ModelsService {
    + getAllProducts(): Promise<Product[]>
    + getProductById(id: number): Promise<Product | undefined>
    + createProduct(): Promise<number>
    + updateProduct(): Promise<void>
    + deleteProduct(): Promise<void>
    + getAllIngredients(): Promise<Ingredient[]>
    + getAllBrands(): Promise<Brand[]>
    + getAllCategories(): Promise<ProductCategory[]>
    + getAllAnalysisLogs(): Promise<AnalysisLog[]>
    + createAnalysisLog(): Promise<number>
    + getAnalysisLogsByDateRange(): Promise<AnalysisLog[]>
    + getAnalysisLogsByCondition(): Promise<AnalysisLog[]>
    + setProductIngredients(): Promise<void>
    + calculateWeights(): Promise<Weights>
  }
  
  class SupabaseClient {
    + from(table: string): QueryBuilder
  }
}

' Relationships
CameraPanel --> SkinAnalyzer : uses
CameraPanel --> FaceDetection : uses
SkinAnalyzer --> FaceDetection : uses
SkinAnalyzer --> CNNSkinClassifier : uses
SkinAnalyzer ..> AnalysisResult : returns
FaceDetection ..> FaceDetectionResult : returns
CNNSkinClassifier ..> CNNPrediction : returns
CNNPrediction ..> SkinScores : converts to

ResultPanel ..> AnalysisResult : displays
RecommendationCard ..> Product : displays

AnalysisAPI --> ModelsService : uses
ProductsAPI --> ModelsService : uses
AnalysisLogsAPI --> ModelsService : uses
ReportsAPI --> ModelsService : uses

ModelsService --> SupabaseClient : uses
ModelsService ..> Product : manages
ModelsService ..> Ingredient : manages
ModelsService ..> Brand : manages
ModelsService ..> AnalysisLog : manages

Product "1" *-- "0..*" Ingredient : contains
Product "0..1" --> "1" Brand : belongs to
Product "0..1" --> "1" ProductCategory : belongs to
AnalysisLog "1" --> "0..*" Product : recommends

note right of CNNSkinClassifier
  **CNN Architecture:**
  Input: 128×128×3
  Conv2D(32) → MaxPool
  Conv2D(64) → MaxPool
  Conv2D(128) → GlobalAvgPool
  Dense(64) → Dense(6) → Softmax
end note

note right of FaceDetection
  **Model:**
  MediaPipe Face Detector
  Runtime: TensorFlow.js
  Backend: WebGL/CPU
end note

note right of AnalysisAPI
  **Recommendation Algorithm:**
  Dot Product Scoring:
  score = Σ(skin_score × product_weight)
  Returns top 3 products
end note

@enduml

