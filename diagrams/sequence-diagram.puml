@startuml Sequence Diagram - Skin Analysis Flow

title Sequence Diagram - Complete Skin Analysis and Recommendation Flow

actor User
participant "CameraPanel\nComponent" as CameraPanel
participant "SkinAnalyzer\nService" as SkinAnalyzer
participant "FaceDetection\nService" as FaceDetection
participant "CNNSkinClassifier\nService" as Classifier
participant "API Route\n/api/analysis" as API
participant "Database\n(Supabase)" as DB
participant "ProductService" as ProductService
participant "ResultPanel\nComponent" as ResultPanel
participant "RecommendationCard\nComponent" as RecCard

User -> CameraPanel: Open application
activate CameraPanel

CameraPanel -> FaceDetection: initializeFaceDetection()
activate FaceDetection
FaceDetection -> FaceDetection: Load MediaPipe model
FaceDetection -> FaceDetection: Initialize TensorFlow.js
FaceDetection --> CameraPanel: Model ready
deactivate FaceDetection

CameraPanel -> SkinAnalyzer: initSkinClassifier()
activate SkinAnalyzer
SkinAnalyzer -> Classifier: loadSkinModel()
activate Classifier
Classifier -> Classifier: Load CNN model from /models/skin-classifier
Classifier --> SkinAnalyzer: Model loaded
deactivate Classifier
SkinAnalyzer --> CameraPanel: Classifier ready
deactivate SkinAnalyzer

alt Camera Mode
  User -> CameraPanel: Request camera access
  CameraPanel -> CameraPanel: getUserMedia()
  CameraPanel --> User: Display video stream
  
  loop Real-time Detection
    CameraPanel -> FaceDetection: detectFaces(video)
    activate FaceDetection
    FaceDetection -> FaceDetection: estimateFaces()
    FaceDetection --> CameraPanel: Face detection result
    deactivate FaceDetection
    CameraPanel -> CameraPanel: Update face box overlay
  end
  
  User -> CameraPanel: Click capture button
else Upload Mode
  User -> CameraPanel: Select image file
  CameraPanel -> CameraPanel: Validate file
  CameraPanel -> CameraPanel: Load image
  CameraPanel -> FaceDetection: detectFaces(image)
  activate FaceDetection
  FaceDetection -> FaceDetection: estimateFaces()
  FaceDetection --> CameraPanel: Face detection result
  deactivate FaceDetection
end

CameraPanel -> SkinAnalyzer: analyzeSkin(video/image)
activate SkinAnalyzer

SkinAnalyzer -> SkinAnalyzer: captureFrame()
SkinAnalyzer -> FaceDetection: detectFacePresenceWithCNN()
activate FaceDetection
FaceDetection -> FaceDetection: detectFaces()
FaceDetection --> SkinAnalyzer: Face detected: true/false
deactivate FaceDetection

alt Face Detected
  SkinAnalyzer -> Classifier: classifySkin(imageData)
  activate Classifier
  
  Classifier -> Classifier: Preprocess image
  note right: Resize to 128x128\nNormalize to [-1, 1]
  
  Classifier -> Classifier: model.predict(tensor)
  note right: CNN Forward Pass\nConv2D → MaxPool → Dense → Softmax
  
  Classifier -> Classifier: Get probabilities
  Classifier -> Classifier: Find argmax (dominant class)
  Classifier -> Classifier: probabilitiesToScores()
  Classifier --> SkinAnalyzer: CNNPrediction {label, probabilities, confidence}
  deactivate Classifier
  
  SkinAnalyzer --> CameraPanel: AnalysisResult
  deactivate SkinAnalyzer
  
  CameraPanel -> API: POST /api/analysis
  activate API
  note right: Payload:\nuser_name, user_age,\nskin scores, etc.
  
  API -> ProductService: getAllProducts()
  activate ProductService
  ProductService -> DB: SELECT * FROM products
  DB --> ProductService: Products list
  deactivate ProductService
  
  API -> API: calculateScore() for each product
  note right: Dot product:\nscore = Σ(skin_score × product_weight)
  
  API -> API: Sort by score (descending)
  API -> API: Select top 3 products
  API -> API: getDominantCondition()
  
  API -> DB: INSERT INTO analysis_logs
  activate DB
  DB --> API: Log ID
  deactivate DB
  
  API --> CameraPanel: Response {recommendations, log_id}
  deactivate API
  
  CameraPanel -> ResultPanel: Display skin scores
  activate ResultPanel
  ResultPanel --> User: Show skin type and scores
  deactivate ResultPanel
  
  CameraPanel -> RecCard: Display recommendations
  activate RecCard
  RecCard -> API: GET /api/products
  activate API
  API -> DB: SELECT * FROM products
  DB --> API: Products
  API --> RecCard: Products list
  deactivate API
  RecCard --> User: Show top 3 products
  deactivate RecCard
  
else No Face Detected
  SkinAnalyzer --> CameraPanel: AnalysisResult {faceDetected: false}
  deactivate SkinAnalyzer
  CameraPanel --> User: Show error message
end

deactivate CameraPanel

@enduml

